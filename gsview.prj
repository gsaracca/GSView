-- GSView
#noedit
#system win32
#model clarion dll
#pragma define(maincode=>off)
#pragma debug(vid=>full)
#pragma check(stack=>on)
#pragma check(index=>on)
#pragma optimize(cpu=>386)
#pragma define(maincode=>off)
#pragma define(_ABCDllMode_=>0)
#pragma define(_ABCLinkMode_=>1)
#compile "gsview.clw"
#compile "gsview001.clw"
#link "gsview.dll"
